# EditorConfig — consistent coding-style across editors and IDEs
# https://editorconfig.org/
root = true

[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size               = 2
insert_final_newline     = true
trim_trailing_whitespace = true
max_line_length          = 100

# Python
[*.{py,pyi}]
indent_size = 4
max_line_length = 100

# Markdown — allow long prose lines
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML — keep trailing newlines
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Shell
[*.sh]
indent_size = 2

# Make
[Makefile]
indent_style = tab
