# Database Configuration
DATABASE_URL=sqlite:///./test.db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_postgres_password
POSTGRES_DB=eurogrant

# Redis / Celery Configuration
CELERY_BROKER_URL=redis://:your_strong_redis_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your_strong_redis_password@redis:6379/0

# AI APIs (NVIDIA NIM)
OPENAI_API_KEY=your_nvidia_nim_api_key
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
PROPOSAL_LLM_MODEL=gpt-4o-mini
PROPOSAL_SECTION_MODEL=gpt-4o-mini
PROPOSAL_MAX_SECTIONS=7
PROPOSAL_LLM_TIMEOUT_SECONDS=60
PROPOSAL_SECTION_MAX_TOKENS=1800
PROPOSAL_CONTEXT_MAX_CHARS=20000
PROPOSAL_SECTION_MAX_JSON_BYTES=200000
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_DIMENSION=1024
ANTHROPIC_API_KEY=your_anthropic_key

# Vector DB (Pinecone)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=eurogrant

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-central-1
S3_BUCKET_NAME=eurogrant-uploads

# Security Configuration
JWT_SECRET=your_cryptographically_secure_jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=CHANGE_ME_IN_PRODUCTION_OR_LEAVE_BLANK

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_GROWTH_PRICE_ID=price_replace_growth
STRIPE_SCALE_PRICE_ID=price_replace_scale
STRIPE_AGENCY_PRICE_ID=price_replace_agency
